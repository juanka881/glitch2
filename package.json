{
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "type": "module",
  "scripts": {
    "check": "tsgo",
    "test": "bun --bun vitest",
    "test:app": "bun --bun vitest run --project app",
    "test:web": "bun --bun vitest run --project web",
    "fmt": "biome format --write",
    "lint": "biome lint --write",
    "web:dev": "vite",
    "web:build": "vite",
    "web:preview": "vite preview",
    "make:agent": "bun run ./scripts/make.ts ./src/agent/main.ts ./dist/glx",
    "make:monitor": "bun run ./scripts/make.ts ./src/monitor/main.ts ./dist/glw",
    "premake": "bun fmt && bun lint && bun check && bun run test",
    "make": "bun make:agent && bun make:monitor"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@socket.io/bun-engine": "^0.1.0",
    "@solidjs/router": "^0.15.4",
    "hono": "^4.12.3",
    "pretty-ms": "^9.3.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "solid-js": "^1.9.11",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@openai/codex": "^0.106.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260228.1",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  }
}
