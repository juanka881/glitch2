{
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsgo",
    "test": "bun test",
    "fmt": "biome format --write",
    "lint": "biome lint --write",
    "make:agent": "bun build --compile ./src/agent/main.ts --outfile ./dist/glx",
    "premake": "bun fmt && bun lint && bun check && bun test",
    "make": "bun make:agent",
    "glx": "bun make:agent && ./dist/glx"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@openai/codex": "^0.106.0",
    "@biomejs/biome": "2.4.4",
    "@types/bun": "^1.3.9",
    "@typescript/native-preview": "^7.0.0-dev.20260228.1"
  }
}
